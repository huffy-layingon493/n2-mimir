{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "sourceMap": true,
    "paths": {
      "../src/*": ["../src/*"]
    }
  },
  "include": ["*.ts"],
  "references": [
    { "path": "../" }
  ]
}
